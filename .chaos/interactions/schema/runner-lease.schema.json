{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaos.local/schema/interaction-runtime/1/chaos-runner-lease.schema.json",
  "title": "CHAOS Runner Lease",
  "description": "Liveness lease written by a live CHAOS interaction runner (Iteration 5). Presence of a non-expired lease is what distinguishes a live, auto-resumable session from a dead one that must fall back to chaos:resume.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "runnerId": {
      "$ref": "#/$defs/id"
    },
    "commandRunId": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 160
    },
    "changeId": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 160
    },
    "sourceCommand": {
      "type": "string",
      "minLength": 1
    },
    "processId": {
      "type": [
        "integer",
        "null"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "created",
        "starting",
        "running",
        "waiting-for-decision",
        "auto-resuming",
        "completed",
        "cancelled",
        "failed",
        "abandoned",
        "ready-for-manual-resume"
      ]
    },
    "startedAt": {
      "$ref": "#/$defs/isoDateTime"
    },
    "lastHeartbeatAt": {
      "$ref": "#/$defs/isoDateTime"
    },
    "leaseExpiresAt": {
      "$ref": "#/$defs/isoDateTime"
    },
    "autoResumeCyclesUsed": {
      "type": "integer",
      "minimum": 0
    },
    "maxAutoResumeCycles": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schemaVersion",
    "runnerId",
    "sourceCommand",
    "state",
    "startedAt",
    "lastHeartbeatAt",
    "leaseExpiresAt",
    "autoResumeCyclesUsed",
    "maxAutoResumeCycles"
  ],
  "$defs": {
    "isoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    }
  }
}
