+    // --- Optimistic concurrency (decision prevent-concurrent-edit-loss / opt-optimistic) ---
+
+    [Fact]
+    public async Task Created_task_starts_at_version_1()
+    {
+        var client = _factory.CreateClient();
+
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Versioned", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        Assert.Equal(1, created!.Version);
+    }
+
+    [Fact]
+    public async Task Version_increments_on_each_successful_update()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "V1", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var updated = await (await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "V2", status = "InProgress", priority = "Low", expectedVersion = created.Version }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        Assert.Equal(2, updated!.Version);
+    }
+
+    [Fact]
+    public async Task Put_with_matching_expected_version_succeeds()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "A", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var response = await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "B", status = "Done", priority = "High", expectedVersion = created.Version });
+
+        Assert.Equal(HttpStatusCode.OK, response.StatusCode);
+    }
+
+    [Fact]
+    public async Task Put_with_stale_expected_version_is_rejected_with_409_and_leaves_task_unchanged()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Original", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        // First writer saved the version they saw (1) -> task advances to version 2.
+        var first = await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "First writer", status = "InProgress", priority = "Medium", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.OK, first.StatusCode);
+
+        // Second writer is still working from the now-stale version 1 -> must be rejected.
+        var second = await client.PutAsJsonAsync(
+            $"/tasks/{created.Id}",
+            new { title = "Second writer (stale)", status = "Done", priority = "High", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.Conflict, second.StatusCode);
+
+        // The stale write must NOT have clobbered the first writer's edit.
+        var fetched = await client.GetFromJsonAsync<TaskDto>($"/tasks/{created.Id}");
+        Assert.Equal("First writer", fetched!.Title);
+        Assert.Equal("InProgress", fetched.Status);
+        Assert.Equal(2, fetched.Version);
+    }
+
