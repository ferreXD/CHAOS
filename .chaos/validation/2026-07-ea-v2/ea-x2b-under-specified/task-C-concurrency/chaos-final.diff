+/// <summary>Outcome of a <see cref="TaskStore.Update"/> call. Pure domain — no HTTP concepts.</summary>
+public enum UpdateOutcome
+{
+    /// <summary>The task was updated; <see cref="UpdateResult.Task"/> is the new record.</summary>
