+    /// <summary>Writes the version as a strong ETag (e.g. <c>"3"</c>) on the response.</summary>
+    private static void SetETag(HttpResponse response, long version) =>
+        response.Headers.ETag = $"\"{version.ToString(CultureInfo.InvariantCulture)}\"";
+
+    /// <summary>
+    /// Parses the version a client is asserting from the <c>If-Match</c> header. Accepts a single
+    /// concrete entity-tag (strong <c>"3"</c> or weak <c>W/"3"</c>). Returns false when the header
+    /// is absent/blank, is a wildcard (<c>*</c>), lists multiple tags, or is otherwise not a
+    /// concrete version — all of which we reject rather than treat as "overwrite anything", since
+    /// bypassing the version check is exactly the failure mode we're closing.
+    /// </summary>
+    private static bool TryGetIfMatchVersion(HttpRequest request, out long version)
+    {
+        version = 0;
+
+        var raw = request.Headers[HeaderNames.IfMatch];
+        if (raw.Count != 1)
+            return false;
+
+        var value = raw.ToString().Trim();
+        if (value.Length == 0 || value == "*")
+            return false;
+
+        // Strip a weak-validator prefix, then the surrounding quotes.
+        if (value.StartsWith("W/", StringComparison.Ordinal))
+            value = value[2..].Trim();
+
+        if (value.Length < 2 || value[0] != '"' || value[^1] != '"')
+            return false;
+
+        var inner = value[1..^1];
+        return long.TryParse(inner, NumberStyles.None, CultureInfo.InvariantCulture, out version);
+    }
 }
