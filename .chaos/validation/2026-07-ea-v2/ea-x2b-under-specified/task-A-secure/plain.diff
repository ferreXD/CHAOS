@@ -0,0 +1,97 @@
+using System.Security.Cryptography;
+using System.Text;
+
+namespace TaskTracker.Api.Security;
+
+/// <summary>
+/// Simple API-key gate. Requests to protected endpoints must carry a valid key in the
+/// <c>X-API-Key</c> header; everything else gets a 401. The expected key is read from
+/// configuration under the <c>ApiKey</c> setting (env var <c>ApiKey</c> or appsettings).
+/// </summary>
+/// <remarks>
+/// Design choices (kept intentionally small for an internal API about to go public):
+/// <list type="bullet">
+/// <item>The root health endpoint (<c>/</c>) stays open so liveness probes don't need a key.</item>
+/// <item>Fails closed: if no key is configured, protected routes reject every request.</item>
+/// <item>Uses a fixed-time comparison so a wrong key can't be teased out via timing.</item>
+/// </list>
+/// </remarks>
+public sealed class ApiKeyMiddleware
+{
+    /// <summary>Header clients must send the key in.</summary>
+    public const string HeaderName = "X-API-Key";
+
+    private readonly RequestDelegate _next;
+    private readonly ILogger<ApiKeyMiddleware> _logger;
+    private readonly byte[]? _expectedKeyBytes;
+
+    public ApiKeyMiddleware(RequestDelegate next, IConfiguration configuration, ILogger<ApiKeyMiddleware> logger)
+    {
+        _next = next;
+        _logger = logger;
+
+        var configuredKey = configuration["ApiKey"];
+        _expectedKeyBytes = string.IsNullOrEmpty(configuredKey)
+            ? null
+            : Encoding.UTF8.GetBytes(configuredKey);
+    }
+
+    public async Task InvokeAsync(HttpContext context)
+    {
+        // Open endpoints (e.g. the health/root check) pass straight through.
+        if (!RequiresApiKey(context.Request.Path))
+        {
+            await _next(context);
+            return;
+        }
+
+        // Fail closed: an unconfigured key means the API is not safe to serve.
+        if (_expectedKeyBytes is null)
+        {
+            _logger.LogError(
+                "No API key configured (set the \"ApiKey\" setting); rejecting request to {Path}.",
+                context.Request.Path);
+            await WriteUnauthorizedAsync(context);
+            return;
+        }
+
+        if (!context.Request.Headers.TryGetValue(HeaderName, out var provided)
+            || provided.Count != 1
+            || !IsValidKey(provided.ToString()))
+        {
+            await WriteUnauthorizedAsync(context);
+            return;
+        }
+
+        await _next(context);
+    }
+
+    /// <summary>Only the data endpoints (<c>/tasks*</c>) are protected; the root health check is open.</summary>
+    private static bool RequiresApiKey(PathString path) =>
+        path.StartsWithSegments("/tasks", StringComparison.OrdinalIgnoreCase);
+
+    private bool IsValidKey(string providedKey)
+    {
+        var providedBytes = Encoding.UTF8.GetBytes(providedKey);
+        // FixedTimeEquals is length-safe and constant-time, avoiding timing side channels.
+        return CryptographicOperations.FixedTimeEquals(providedBytes, _expectedKeyBytes!);
+    }
+
+    private static async Task WriteUnauthorizedAsync(HttpContext context)
+    {
+        context.Response.StatusCode = StatusCodes.Status401Unauthorized;
+        context.Response.Headers.WWWAuthenticate = $"ApiKey header=\"{HeaderName}\"";
+        await context.Response.WriteAsJsonAsync(new
+        {
+            error = $"A valid API key is required. Send it in the {HeaderName} header."
+        });
+    }
+}
+
+/// <summary>Registration helper for <see cref="ApiKeyMiddleware"/>.</summary>
+public static class ApiKeyMiddlewareExtensions
+{
+    /// <summary>Adds the API-key gate to the request pipeline.</summary>
+    public static IApplicationBuilder UseApiKeyAuth(this IApplicationBuilder app) =>
+        app.UseMiddleware<ApiKeyMiddleware>();
+}
