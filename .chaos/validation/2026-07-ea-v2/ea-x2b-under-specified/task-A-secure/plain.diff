+/// <summary>
+/// Boots the API with a known API key injected via configuration, so tests can authenticate
+/// deterministically without depending on appsettings files or environment.
+/// </summary>
+public class ApiKeyWebApplicationFactory : WebApplicationFactory<Program>
+{
+    /// <summary>The key the test host expects in the <c>X-API-Key</c> header.</summary>
+    public const string ApiKey = "test-api-key-123";
+
+    protected override void ConfigureWebHost(IWebHostBuilder builder)
+    {
+        builder.ConfigureAppConfiguration((_, config) =>
+        {
+            config.AddInMemoryCollection(new Dictionary<string, string?>
+            {
+                ["ApiKey"] = ApiKey
+            });
+        });
+    }
+}
