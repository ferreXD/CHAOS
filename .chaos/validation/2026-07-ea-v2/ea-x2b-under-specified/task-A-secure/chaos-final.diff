index 0000000..681ce1e
--- /dev/null
+++ b/src/TaskTracker.Api/Security/ApiKeyEndpointFilter.cs
@@ -0,0 +1,54 @@
+namespace TaskTracker.Api.Security;
+
+/// <summary>
+/// Enforces a shared-secret API key on the endpoints it is attached to.
+///
+/// Governance: implements the human-answered decisions for change
+/// <c>secure-api-public-exposure</c> (see
+/// <c>.chaos/changes/secure-api-public-exposure/decision-events.md</c>):
+/// <list type="bullet">
+///   <item>SEC-DEC-001 → <b>reads-public / writes-protected</b>: this filter is applied ONLY to the
+///     write routes (<c>POST</c>/<c>PUT</c>/<c>DELETE</c> on <c>/tasks</c>). <c>GET /tasks</c>,
+///     <c>GET /tasks/{id}</c> and the <c>GET /</c> health endpoint stay public and never see it.</item>
+///   <item>SEC-DEC-002 → single shared secret read from configuration key <c>ApiKey</c>, defaulting
+///     to <c>test-secret-key</c> when unset. No per-consumer identity, no key store.</item>
+///   <item>SEC-DEC-003 → the key travels in the <c>X-Api-Key</c> request header; a missing or invalid
+///     key yields <c>401 Unauthorized</c>.</item>
+/// </list>
+///
+/// This is an HTTP-pipeline concern only: it depends on ASP.NET Core + configuration and never on the
+/// domain layer, preserving the domain→HTTP boundary (R-004).
+/// </summary>
+public sealed class ApiKeyEndpointFilter : IEndpointFilter
+{
+    /// <summary>Request header that carries the API key (SEC-DEC-003).</summary>
+    public const string HeaderName = "X-Api-Key";
+
+    /// <summary>Configuration key the valid secret is read from (SEC-DEC-002).</summary>
+    public const string ConfigKey = "ApiKey";
+
+    /// <summary>Fallback secret used when <see cref="ConfigKey"/> is unset (SEC-DEC-002).</summary>
+    public const string DefaultKey = "test-secret-key";
+
+    private readonly string _validKey;
+
+    public ApiKeyEndpointFilter(IConfiguration configuration)
+    {
+        // Read once from configuration; fall back to the demo default when unset.
+        _validKey = configuration[ConfigKey] ?? DefaultKey;
+    }
+
+    public async ValueTask<object?> InvokeAsync(
+        EndpointFilterInvocationContext context, EndpointFilterDelegate next)
+    {
+        var provided = context.HttpContext.Request.Headers[HeaderName].ToString();
+
+        if (string.IsNullOrEmpty(provided) || !string.Equals(provided, _validKey, StringComparison.Ordinal))
+        {
+            // Missing or invalid credential — reject before the handler runs.
+            return Results.Unauthorized();
+        }
+
+        return await next(context);
+    }
+}
