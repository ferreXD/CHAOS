diff --git a/tests/TaskTracker.Tests/TaskEndpointsTests.cs b/tests/TaskTracker.Tests/TaskEndpointsTests.cs
index d2870e9..e869360 100644
--- a/tests/TaskTracker.Tests/TaskEndpointsTests.cs
+++ b/tests/TaskTracker.Tests/TaskEndpointsTests.cs
@@ -79,6 +79,83 @@ public class TaskEndpointsTests : IClassFixture<WebApplicationFactory<Program>>
         Assert.Equal(HttpStatusCode.NotFound, getAfter.StatusCode);
     }
 
+    // --- Soft-delete / recoverable Trash (change: delete-tasks-product; MD-001 = opt-soft-trash) ---
+
+    [Fact]
+    public async Task Delete_soft_deletes_task_hiding_it_from_the_list_but_keeping_it_in_trash()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Soft-delete me", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var delete = await client.DeleteAsync($"/tasks/{created!.Id}");
+        Assert.Equal(HttpStatusCode.NoContent, delete.StatusCode);
+
+        // Hidden from the normal list...
+        var active = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+        Assert.DoesNotContain(active!, t => t.Id == created.Id);
+
+        // ...but NOT destroyed — it is retained in the recoverable Trash, with DeletedAt stamped.
+        var trash = await client.GetFromJsonAsync<List<TaskDto>>("/tasks/trash");
+        var trashed = Assert.Single(trash!, t => t.Id == created.Id);
+        Assert.NotNull(trashed.DeletedAt);
+    }
+
+    [Fact]
+    public async Task Deleted_task_can_be_restored_from_trash()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Restore me", status = "InProgress", priority = "High" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        await client.DeleteAsync($"/tasks/{created!.Id}");
+
+        var restore = await client.PostAsync($"/tasks/{created.Id}/restore", content: null);
+        Assert.Equal(HttpStatusCode.OK, restore.StatusCode);
+
+        var restored = await restore.Content.ReadFromJsonAsync<TaskDto>();
+        Assert.NotNull(restored);
+        Assert.Null(restored!.DeletedAt);
+        // Status/priority survive the delete→restore round-trip.
+        Assert.Equal("InProgress", restored.Status);
+        Assert.Equal("High", restored.Priority);
+
+        // Back in the normal list and reachable by id; no longer in the Trash.
+        var getAfter = await client.GetAsync($"/tasks/{created.Id}");
+        Assert.Equal(HttpStatusCode.OK, getAfter.StatusCode);
+
+        var active = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+        Assert.Contains(active!, t => t.Id == created.Id);
+
+        var trash = await client.GetFromJsonAsync<List<TaskDto>>("/tasks/trash");
+        Assert.DoesNotContain(trash!, t => t.Id == created.Id);
+    }
+
+    [Fact]
+    public async Task Restore_unknown_task_returns_not_found()
+    {
+        var client = _factory.CreateClient();
+
+        var restore = await client.PostAsync($"/tasks/{Guid.NewGuid()}/restore", content: null);
+
+        Assert.Equal(HttpStatusCode.NotFound, restore.StatusCode);
+    }
+
+    [Fact]
+    public async Task Seeded_tasks_remain_active_and_trash_starts_empty_of_them()
+    {
+        var client = _factory.CreateClient();
+
+        var active = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+        Assert.Contains(active!, t => t.Title == "Add query-param filters to GET /tasks");
+
+        // No seeded task is trashed on startup — seeded tasks remain active.
+        var trash = await client.GetFromJsonAsync<List<TaskDto>>("/tasks/trash");
+        Assert.DoesNotContain(trash!, t => t.Title == "Add query-param filters to GET /tasks");
+    }
+
