+    /// <summary>
+    /// Soft-delete: move a live task to the recoverable Trash by stamping <c>DeletedAt</c>.
+    /// The record is NEVER destroyed. Returns <c>true</c> when a live task was moved to Trash;
+    /// <c>false</c> if the id is unknown or the task is already trashed (nothing to do).
+    /// </summary>
+    public bool SoftDelete(Guid id)
+    {
+        if (!_tasks.TryGetValue(id, out var existing) || existing.IsDeleted)
+            return false;
+
+        _tasks[id] = existing with { DeletedAt = DateTimeOffset.UtcNow };
+        return true;
+    }
+
+    /// <summary>
+    /// Restore a soft-deleted task from the Trash (clears <c>DeletedAt</c>), preserving its
+    /// status/priority/title. Returns the restored task, or <c>null</c> if the id is unknown
+    /// or the task is not currently trashed.
+    /// </summary>
+    public TaskItem? Restore(Guid id)
+    {
+        if (!_tasks.TryGetValue(id, out var existing) || !existing.IsDeleted)
+            return null;
+
+        var restored = existing with { DeletedAt = null };
+        _tasks[id] = restored;
+        return restored;
+    }
+
+    /// <summary>
+    /// Permanent hard delete. Retained for internal/administrative use only — it is NOT wired to
+    /// the user-facing <c>DELETE</c> endpoint, which now soft-deletes (MD-001 = opt-soft-trash).
+    /// </summary>
     public bool Remove(Guid id) => _tasks.TryRemove(id, out _);
 
     private TaskItem AddAt(string title, TaskState status, TaskPriority priority, DateTimeOffset createdAt)
