 /// <summary>An immutable task record held in the in-memory store.</summary>
+/// <remarks>
+/// <see cref="DeletedAt"/> is the soft-delete marker (change: delete-tasks-product, MD-001 =
+/// <c>opt-soft-trash</c>). A user-facing delete does NOT remove the record; it stamps
+/// <see cref="DeletedAt"/> so the task moves to a recoverable Trash (hidden from the normal
+/// list, restorable). <c>null</c> = active. Deliberately a separate marker rather than a new
+/// <see cref="TaskState"/> value, so the work-item status (Open/InProgress/Done) is preserved
+/// across delete→restore and R-005 (<c>TaskState</c> naming) is untouched.
+/// </remarks>
 public record TaskItem(
     Guid Id,
     string Title,
     TaskState Status,
     TaskPriority Priority,
-    DateTimeOffset CreatedAt);
+    DateTimeOffset CreatedAt,
+    DateTimeOffset? DeletedAt = null)
+{
+    /// <summary><c>true</c> when the task is soft-deleted (in the recoverable Trash).</summary>
+    public bool IsDeleted => DeletedAt is not null;
+}
