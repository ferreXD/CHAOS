+    [Fact]
+    public async Task Delete_then_restore_brings_the_task_back()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Undo me", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var delete = await client.DeleteAsync($"/tasks/{created!.Id}");
+        Assert.Equal(HttpStatusCode.NoContent, delete.StatusCode);
+
+        // Gone from the live view while trashed.
+        Assert.Equal(HttpStatusCode.NotFound, (await client.GetAsync($"/tasks/{created.Id}")).StatusCode);
+
+        var restore = await client.PostAsync($"/tasks/{created.Id}/restore", content: null);
+        Assert.Equal(HttpStatusCode.OK, restore.StatusCode);
+        var restored = await restore.Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal("Undo me", restored!.Title);
+        Assert.Null(restored.DeletedAt);
+
+        // Back in the live view, fetchable again.
+        var fetched = await client.GetFromJsonAsync<TaskDto>($"/tasks/{created.Id}");
+        Assert.Equal("Undo me", fetched!.Title);
+    }
+
+    [Fact]
+    public async Task Deleted_task_leaves_the_list_and_shows_up_in_the_trash()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Trash me", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        await client.DeleteAsync($"/tasks/{created!.Id}");
+
+        var live = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+        Assert.DoesNotContain(live!, t => t.Id == created.Id);
+
+        var trash = await client.GetFromJsonAsync<List<TaskDto>>("/tasks/deleted");
+        var trashed = Assert.Single(trash!, t => t.Id == created.Id);
+        Assert.NotNull(trashed.DeletedAt);
+    }
+
+    [Fact]
+    public async Task Deleting_an_already_deleted_task_returns_not_found()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Twice", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        Assert.Equal(HttpStatusCode.NoContent, (await client.DeleteAsync($"/tasks/{created!.Id}")).StatusCode);
+        Assert.Equal(HttpStatusCode.NotFound, (await client.DeleteAsync($"/tasks/{created.Id}")).StatusCode);
+    }
+
+    [Fact]
+    public async Task Restoring_something_that_was_not_deleted_returns_not_found()
+    {
+        var client = _factory.CreateClient();
+
+        // Unknown id.
+        Assert.Equal(HttpStatusCode.NotFound,
+            (await client.PostAsync($"/tasks/{Guid.NewGuid()}/restore", content: null)).StatusCode);
+
+        // A live task that is not in the trash.
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Still here", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal(HttpStatusCode.NotFound,
+            (await client.PostAsync($"/tasks/{created!.Id}/restore", content: null)).StatusCode);
+    }
+
