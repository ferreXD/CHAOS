+    /// <summary>
+    /// Soft-deletes a task: stamps <see cref="TaskItem.DeletedAt"/> instead of dropping the record,
+    /// so it can be restored. Returns <c>true</c> only when a live task was moved to the trash;
+    /// <c>false</c> for an unknown id or one that was already deleted (so a repeat delete is a no-op).
+    /// </summary>
+    public bool Remove(Guid id)
+    {
+        while (true)
+        {
+            if (!_tasks.TryGetValue(id, out var existing) || existing.DeletedAt is not null)
+                return false;
+
+            var deleted = existing with { DeletedAt = DateTimeOffset.UtcNow };
+            if (_tasks.TryUpdate(id, deleted, existing))
+                return true;
+            // Lost a race with a concurrent writer; re-read and retry.
+        }
+    }
+
+    /// <summary>
+    /// Undoes a soft delete, bringing a task back to the live list. Returns the restored task, or
+    /// <c>null</c> if no trashed task with that id exists (nothing to undo).
+    /// </summary>
+    public TaskItem? Restore(Guid id)
+    {
+        while (true)
+        {
+            if (!_tasks.TryGetValue(id, out var existing) || existing.DeletedAt is null)
+                return null;
+
+            var restored = existing with { DeletedAt = null };
+            if (_tasks.TryUpdate(id, restored, existing))
+                return restored;
+            // Lost a race with a concurrent writer; re-read and retry.
+        }
+    }
 
