+namespace TaskTracker.Api.Endpoints;
+
+/// <summary>
+/// API-key authentication for the <c>/tasks</c> routes.
+/// </summary>
+/// <remarks>
+/// Runs as a group-level <see cref="IEndpointFilter"/> so it executes BEFORE any task
+/// endpoint handler — a request with a missing or incorrect <c>X-Api-Key</c> header is
+/// rejected with <c>401 Unauthorized</c> before the handler reads (existence) or mutates
+/// (validation/persistence) any task. The expected key is the configuration value
+/// <c>ApiKey</c>, defaulting to <c>test-secret-key</c> when it is not set.
+///
+/// This lives in the HTTP layer by design: the domain (<c>Domain/**</c>) never sees
+/// ASP.NET Core types (R-004). The root health endpoint <c>GET /</c> is mapped outside the
+/// <c>/tasks</c> group, so it stays public.
+/// </remarks>
+public sealed class ApiKeyEndpointFilter : IEndpointFilter
+{
+    /// <summary>Request header carrying the API key.</summary>
+    public const string HeaderName = "X-Api-Key";
+
+    /// <summary>Configuration key holding the valid API key.</summary>
+    public const string ConfigKey = "ApiKey";
+
+    /// <summary>Fallback API key used when <see cref="ConfigKey"/> is not configured.</summary>
+    public const string DefaultApiKey = "test-secret-key";
+
+    private readonly string _expectedKey;
+
+    public ApiKeyEndpointFilter(IConfiguration configuration)
+    {
+        var configured = configuration[ConfigKey];
+        _expectedKey = string.IsNullOrWhiteSpace(configured) ? DefaultApiKey : configured;
+    }
+
+    public async ValueTask<object?> InvokeAsync(
+        EndpointFilterInvocationContext context, EndpointFilterDelegate next)
+    {
+        var provided = context.HttpContext.Request.Headers[HeaderName].ToString();
+
+        if (string.IsNullOrEmpty(provided) || !string.Equals(provided, _expectedKey, StringComparison.Ordinal))
+        {
+            return Results.Unauthorized();
+        }
+
+        return await next(context);
+    }
+}
diff --git a/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs b/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs
index 612f44c..d10e4cd 100644
--- a/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs
+++ b/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs
@@ -17,6 +17,11 @@ public static class TaskEndpoints
     {
         var group = app.MapGroup("/tasks");
 
+        // API-key authentication for every /tasks route. The filter runs before each handler,
+        // so a missing/incorrect X-Api-Key header is rejected with 401 Unauthorized before any
+        // task is read or mutated. GET / (root health) is mapped outside this group and stays public.
+        group.AddEndpointFilter<ApiKeyEndpointFilter>();
+
         // GET /tasks — returns every task in the store. No filtering (yet).
         group.MapGet("/", (TaskStore store) => Results.Ok(store.All()));
 
