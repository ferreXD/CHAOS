diff --git a/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs b/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs
index 612f44c..e18a570 100644
--- a/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs
+++ b/src/TaskTracker.Api/Endpoints/TaskEndpoints.cs
@@ -13,10 +13,33 @@ namespace TaskTracker.Api.Endpoints;
 /// </remarks>
 public static class TaskEndpoints
 {
+    /// <summary>Header carrying the API key on every <c>/tasks</c> request.</summary>
+    private const string ApiKeyHeader = "X-Api-Key";
+
+    /// <summary>Configuration key holding the valid API key.</summary>
+    private const string ApiKeyConfigKey = "ApiKey";
+
+    /// <summary>Fallback API key used when <c>ApiKey</c> is not configured.</summary>
+    private const string DefaultApiKey = "test-secret-key";
+
     public static IEndpointRouteBuilder MapTaskEndpoints(this IEndpointRouteBuilder app)
     {
         var group = app.MapGroup("/tasks");
 
+        // Require a valid API key on every /tasks route. Runs as a group-level endpoint filter,
+        // so it executes before any route handler — i.e. before any existence/validation check and
+        // before the store is read or mutated. Missing/incorrect key => 401 Unauthorized.
+        var validApiKey = app.ServiceProvider.GetRequiredService<IConfiguration>()[ApiKeyConfigKey]
+            ?? DefaultApiKey;
+        group.AddEndpointFilter(async (context, next) =>
+        {
+            var provided = context.HttpContext.Request.Headers[ApiKeyHeader].ToString();
+            if (!string.Equals(provided, validApiKey, StringComparison.Ordinal))
+                return Results.Unauthorized();
+
+            return await next(context);
+        });
+
         // GET /tasks — returns every task in the store. No filtering (yet).
         group.MapGet("/", (TaskStore store) => Results.Ok(store.All()));
 
