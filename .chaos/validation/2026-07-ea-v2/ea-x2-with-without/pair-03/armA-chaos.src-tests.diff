+    // --- Optimistic concurrency (version + expectedVersion) ---
+
+    [Fact]
+    public async Task Post_creates_a_task_at_version_1()
+    {
+        var client = _factory.CreateClient();
+
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Versioned", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        Assert.Equal(1, created!.Version);
+    }
+
+    [Fact]
+    public async Task Seeded_tasks_start_at_version_1()
+    {
+        var client = _factory.CreateClient();
+
+        var tasks = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+
+        Assert.NotNull(tasks);
+        // A seeded task never mutated by another test is still at version 1.
+        Assert.Contains(tasks!, t => t.Title == "Write the project README" && t.Version == 1);
+    }
+
+    [Fact]
+    public async Task Put_without_expected_version_increments_version()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Draft", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal(1, created!.Version);
+
+        // No expectedVersion => backward-compatible unconditional update, version still increments.
+        var updated = await (await client.PutAsJsonAsync(
+            $"/tasks/{created.Id}", new { title = "Draft v2", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        Assert.Equal(2, updated!.Version);
+        Assert.Equal("Draft v2", updated.Title);
+    }
+
+    [Fact]
+    public async Task Put_with_matching_expected_version_succeeds_and_increments()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Doc", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var response = await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "Doc final", status = "Done", priority = "Medium", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.OK, response.StatusCode);
+
+        var updated = await response.Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal(2, updated!.Version);
+        Assert.Equal("Doc final", updated.Title);
+        Assert.Equal("Done", updated.Status);
+    }
+
+    [Fact]
+    public async Task Put_with_stale_expected_version_conflicts_and_leaves_task_unchanged()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Race", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        // First writer holds the fresh version (1) and succeeds: 1 -> 2.
+        var first = await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "Race by A", status = "InProgress", priority = "Medium", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.OK, first.StatusCode);
+
+        // Second writer holds a stale version (1) and must be rejected without touching the task.
+        var second = await client.PutAsJsonAsync(
+            $"/tasks/{created.Id}",
+            new { title = "Race by B", status = "Done", priority = "High", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.Conflict, second.StatusCode);
+
+        // The task is exactly the first writer's result: no field changed, version not bumped.
+        var fetched = await client.GetFromJsonAsync<TaskDto>($"/tasks/{created.Id}");
+        Assert.Equal("Race by A", fetched!.Title);
+        Assert.Equal("InProgress", fetched.Status);
+        Assert.Equal("Medium", fetched.Priority);
+        Assert.Equal(2, fetched.Version);
+    }
