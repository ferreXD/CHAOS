+    [Fact]
+    public async Task Post_creates_a_task_at_version_1()
+    {
+        var client = _factory.CreateClient();
+
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Fresh", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        Assert.Equal(1, created!.Version);
+    }
+
+    [Fact]
+    public async Task Seeded_tasks_start_at_version_1()
+    {
+        var client = _factory.CreateClient();
+
+        var tasks = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+
+        // The store is a process-wide singleton shared across the test class, so other tests'
+        // POST/PUT calls also appear here. Scope the assertion to the known seeded tasks, which
+        // no test mutates.
+        var seededTitles = new[]
+        {
+            "Write the project README",
+            "Add query-param filters to GET /tasks",
+            "Review the CHAOS proposal",
+            "Clean up sample data"
+        };
+        foreach (var title in seededTitles)
+        {
+            var seeded = Assert.Single(tasks!, t => t.Title == title);
+            Assert.Equal(1, seeded.Version);
+        }
+    }
+
+    [Fact]
+    public async Task Put_without_expected_version_increments_version()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Draft", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal(1, created!.Version);
+
+        var update = await client.PutAsJsonAsync(
+            $"/tasks/{created.Id}", new { title = "Final", status = "Done", priority = "Medium" });
+        Assert.Equal(HttpStatusCode.OK, update.StatusCode);
+
+        var updated = await update.Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal(2, updated!.Version);
+
+        // A second unconditional update keeps climbing: 2 -> 3.
+        var again = await client.PutAsJsonAsync(
+            $"/tasks/{created.Id}", new { title = "Final v2", status = "Done", priority = "High" });
+        var updatedAgain = await again.Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal(3, updatedAgain!.Version);
+    }
+
+    [Fact]
+    public async Task Put_with_matching_expected_version_succeeds_and_increments()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Draft", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var update = await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "Final", status = "Done", priority = "Medium", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.OK, update.StatusCode);
+
+        var updated = await update.Content.ReadFromJsonAsync<TaskDto>();
+        Assert.Equal("Final", updated!.Title);
+        Assert.Equal(2, updated.Version);
+    }
+
+    [Fact]
+    public async Task Put_with_stale_expected_version_is_rejected_with_conflict_and_leaves_task_unchanged()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Draft", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        // First writer wins with matching expectedVersion; task moves to version 2.
+        await client.PutAsJsonAsync(
+            $"/tasks/{created!.Id}",
+            new { title = "First writer", status = "InProgress", priority = "High", expectedVersion = 1 });
+
+        // Second writer still thinks it's version 1 -> must be rejected, task untouched.
+        var stale = await client.PutAsJsonAsync(
+            $"/tasks/{created.Id}",
+            new { title = "Stale writer", status = "Done", priority = "Low", expectedVersion = 1 });
+        Assert.Equal(HttpStatusCode.Conflict, stale.StatusCode);
+
+        var fetched = await client.GetFromJsonAsync<TaskDto>($"/tasks/{created.Id}");
+        Assert.Equal("First writer", fetched!.Title);
+        Assert.Equal("InProgress", fetched.Status);
+        Assert.Equal(2, fetched.Version); // not bumped by the rejected update
+    }
