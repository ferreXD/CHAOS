-    public bool Remove(Guid id) => _tasks.TryRemove(id, out _);
+    /// <summary>
+    /// Soft-deletes the task: stamps <see cref="TaskItem.DeletedAt"/> with <paramref name="deletedAt"/>
+    /// instead of removing the row, so it is retained but hidden by default. Resolves against physical
+    /// existence — a task that physically exists (even one already soft-deleted) is stamped and returns
+    /// <c>true</c>; only a never-existent id returns <c>false</c> (→ 404). The task is never removed.
+    /// </summary>
+    public bool SoftDelete(Guid id, DateTimeOffset deletedAt)
+    {
+        if (!_tasks.TryGetValue(id, out var existing))
+            return false;
+
+        _tasks[id] = existing with { DeletedAt = deletedAt };
+        return true;
+    }
 
