+    // --- Soft-delete (change: soft-delete-tasks) ---------------------------------------------
+
+    [Fact]
+    public async Task Seeded_tasks_are_active_with_null_deletedAt()
+    {
+        var client = _factory.CreateClient();
+
+        var tasks = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+
+        Assert.NotNull(tasks);
+        var seeded = tasks!.Where(t =>
+            t.Title is "Write the project README"
+                or "Add query-param filters to GET /tasks"
+                or "Review the CHAOS proposal"
+                or "Clean up sample data");
+        Assert.Equal(4, seeded.Count());
+        Assert.All(seeded, t => Assert.Null(t.DeletedAt));
+    }
+
+    [Fact]
+    public async Task Active_task_serializes_deletedAt_as_null()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Active", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        // The field must be present and literally null on an active task.
+        var raw = await client.GetStringAsync($"/tasks/{created!.Id}");
+        Assert.Contains("\"deletedAt\":null", raw.Replace(" ", ""));
+    }
+
+    [Fact]
+    public async Task Delete_soft_deletes_task_returns_204_and_hides_it()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "To be soft-deleted", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+
+        var delete = await client.DeleteAsync($"/tasks/{created!.Id}");
+        Assert.Equal(HttpStatusCode.NoContent, delete.StatusCode);
+
+        // GET /tasks/{id} now 404s for the soft-deleted task.
+        var getById = await client.GetAsync($"/tasks/{created.Id}");
+        Assert.Equal(HttpStatusCode.NotFound, getById.StatusCode);
+
+        // GET /tasks (default) excludes it.
+        var active = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+        Assert.DoesNotContain(active!, t => t.Id == created.Id);
+
+        // GET /tasks?includeDeleted=true includes it, with a non-null deletedAt.
+        var all = await client.GetFromJsonAsync<List<TaskDto>>("/tasks?includeDeleted=true");
+        var deleted = all!.Single(t => t.Id == created.Id);
+        Assert.NotNull(deleted.DeletedAt);
+    }
+
+    [Fact]
+    public async Task Delete_unknown_id_returns_404()
+    {
+        var client = _factory.CreateClient();
+
+        var delete = await client.DeleteAsync($"/tasks/{Guid.NewGuid()}");
+
+        Assert.Equal(HttpStatusCode.NotFound, delete.StatusCode);
+    }
+
+    [Fact]
+    public async Task Get_tasks_excludes_soft_deleted_by_default_but_includeDeleted_returns_them()
+    {
+        var client = _factory.CreateClient();
+        var created = await (await client.PostAsJsonAsync(
+            "/tasks", new { title = "Filtered out when deleted", status = "Open", priority = "Low" }))
+            .Content.ReadFromJsonAsync<TaskDto>();
+        await client.DeleteAsync($"/tasks/{created!.Id}");
+
+        var defaultList = await client.GetFromJsonAsync<List<TaskDto>>("/tasks");
+        var includingDeleted = await client.GetFromJsonAsync<List<TaskDto>>("/tasks?includeDeleted=true");
+
+        Assert.DoesNotContain(defaultList!, t => t.Id == created.Id);
+        Assert.Contains(includingDeleted!, t => t.Id == created.Id && t.DeletedAt is not null);
+    }
