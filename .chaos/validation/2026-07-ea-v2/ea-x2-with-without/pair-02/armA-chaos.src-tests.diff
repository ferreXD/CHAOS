 /// <summary>An immutable task record held in the in-memory store.</summary>
+/// <remarks>
+/// <see cref="DeletedAt"/> is a nullable soft-delete marker: <c>null</c> means the task is active,
+/// a non-null value is the instant it was soft-deleted. It is a trailing, defaulted positional
+/// parameter so every pre-existing construction site (seeds, <c>Add</c>) keeps compiling and yields
+/// an active task — the backward-compatible "migration" for existing rows. Serialized as
+/// <c>deletedAt</c> (camelCase web defaults): an ISO-8601 string when set, <c>null</c> when active.
+/// </remarks>
 public record TaskItem(
     Guid Id,
     string Title,
     TaskState Status,
     TaskPriority Priority,
-    DateTimeOffset CreatedAt);
+    DateTimeOffset CreatedAt,
+    DateTimeOffset? DeletedAt = null);
