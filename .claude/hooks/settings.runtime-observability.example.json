{
  "$comment": "Example hook wiring for the CHAOS vNext runtime-observability hooks (see ../README.md and reference/hook-runtime-policy.md). This file is illustrative only and is not read directly by Claude Code. Copy the \"hooks\" object from whichever profile you want into your own .claude/settings.json or .claude/settings.local.json, merging with any hooks already present there (this repository's committed .claude/settings.json already wires PostToolUse/Stop to chaos-artifact-metadata-hook.py -- add these entries alongside it, do not replace it). Both profiles are report-only: they populate .chaos/runtime/* and log warnings, but never block a turn and never touch files outside .chaos/runtime/.",
  "profiles": {
    "reportOnly": {
      "description": "Recommended default. Writes session/command/touched-file/stop observability state under .chaos/runtime/. Never exits non-zero.",
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event session-start",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-active-command.py\" --event session-start",
                "timeout": 10
              }
            ]
          }
        ],
        "UserPromptSubmit": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event user-prompt-submit",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-active-command.py\" --event user-prompt-submit",
                "timeout": 10
              }
            ]
          }
        ],
        "PostToolUse": [
          {
            "matcher": "Edit|Write|MultiEdit|Bash",
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-touched-files.py\" --event post-tool-use",
                "timeout": 15
              }
            ]
          }
        ],
        "Stop": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event stop",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-stop-summary.py\" --event stop",
                "timeout": 20
              }
            ]
          }
        ]
      }
    },
    "strict": {
      "description": "Same wiring as reportOnly, plus --strict on every invocation. Still only affects exit code on critical runtime errors (e.g. an unreadable/corrupt .chaos/runtime/*.json file) -- ordinary findings like missing expected artifacts or undetected commands remain warnings, never blocks.",
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event session-start --strict",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-active-command.py\" --event session-start --strict",
                "timeout": 10
              }
            ]
          }
        ],
        "UserPromptSubmit": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event user-prompt-submit --strict",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-active-command.py\" --event user-prompt-submit --strict",
                "timeout": 10
              }
            ]
          }
        ],
        "PostToolUse": [
          {
            "matcher": "Edit|Write|MultiEdit|Bash",
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-touched-files.py\" --event post-tool-use --strict",
                "timeout": 15
              }
            ]
          }
        ],
        "Stop": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event stop --strict",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-stop-summary.py\" --event stop --strict",
                "timeout": 20
              }
            ]
          }
        ]
      }
    },
    "sessionAndCommandOnly": {
      "description": "Minimal footprint: only SessionStart/UserPromptSubmit context+command detection. Skips touched-file auditing and the stop summary -- useful if you only want session-context.json/active-command.json kept fresh for the artifact-metadata hook to consume (it already reads them if present).",
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event session-start",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-active-command.py\" --event session-start",
                "timeout": 10
              }
            ]
          }
        ],
        "UserPromptSubmit": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-session-context.py\" --event user-prompt-submit",
                "timeout": 20
              },
              {
                "type": "command",
                "command": "py -3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scripts/chaos-active-command.py\" --event user-prompt-submit",
                "timeout": 10
              }
            ]
          }
        ]
      }
    }
  }
}
